# O nome do banco de dados específico dentro do seu servidor PostgreSQL onde as tabelas foram criadas
DB_NAME=Apollo_db

# O nome do usuário que tem permissão para acessar o banco (o padrão de instalação é 'postgres')
DB_USER=postgres

# A senha secreta definida para esse usuário durante a instalação do banco de dados
DB_PASS=admin

# O endereço de rede onde o banco de dados está rodando
# 'localhost' ou '127.0.0.1' indica que o banco está na mesma máquina que o código da API
DB_HOST=localhost

# A porta de comunicação do servidor PostgreSQL (o valor padrão de fábrica é 5432)
DB_PORT=5432

PORT=3000